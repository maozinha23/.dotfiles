# ------------------------------------------------------------------------------
# VARIABLES
# ------------------------------------------------------------------------------
# Define names for default workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
# ------------------------------------------------------------------------------
# CONFIG
# ------------------------------------------------------------------------------
# Include configuration files
include /etc/sway/config.d/*
include ${HOME}/.config/sway/*.conf

# Set workspaces for some applications
assign [app_id="foot"] $ws1
assign [app_id="firefox"] $ws2
# assign [app_id="feh"] $ws3
assign [app_id="mpv"] $ws3
assign [app_id="gimp"] $ws4
assign [app_id="libreoffice-*"] $ws4
# assign [app_id="(?i)arandr"] $ws5
assign [app_id="blueman-manager"] $ws5
assign [app_id="io.missioncenter.MissionCenter"] $ws5
assign [app_id="xarchiver"] $ws5
